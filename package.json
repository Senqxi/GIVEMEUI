{
  "name": "givemeui",
  "version": "0.1.0",
  "description": "Local-first CLI-to-UI generator for terminal tools.",
  "license": "MIT",
  "type": "module",
  "preferGlobal": true,
  "homepage": "https://github.com/Senqxi/GIVEMEUI#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Senqxi/GIVEMEUI.git"
  },
  "bugs": {
    "url": "https://github.com/Senqxi/GIVEMEUI/issues"
  },
  "bin": {
    "givemeui": "./bin/givemeui.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "docs/",
    "packaging/",
    "scripts/",
    "server/",
    "src/lib/",
    "public/",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "ui",
    "terminal",
    "local-first",
    "developer-tools"
  ],
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "npm run typecheck && vite build",
    "postinstall": "node scripts/fix-node-pty-permissions.mjs",
    "start": "node bin/givemeui.mjs",
    "typecheck": "tsc -p tsconfig.app.json --noEmit --pretty false && tsc -p tsconfig.node.json --noEmit --pretty false",
    "test": "vitest run",
    "test:app": "vitest run tests/app.integration.test.tsx",
    "preview": "vite preview --host 127.0.0.1",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run",
    "package:local": "node scripts/package-local.mjs",
    "release:check": "npm run typecheck && npm run test && npm run pack:check"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.14.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^18.19.112",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^27.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^3.2.6"
  }
}
